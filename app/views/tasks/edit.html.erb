<% content_for :title, "Editing task" %>

<div class="container">
  <h3 class="center-align todo-title">Edit Task</h3>
  <div class="row">
    <div class="col s12 m8 offset-m2 l6 offset-l3">
      <%= render "form", task: @task %>
      <div class="center-align" style="margin-top: 1.5rem;">
        <%= link_to "Show this task", @task, class: "btn-flat blue-text" %> |
        <%= link_to "Back to tasks", tasks_path, class: "btn-flat blue-text" %>
      </div>
    </div>
  </div>
</div>
