<div class="container">
  <div class="row">
    <div class="col s12 m8 offset-m2 l6 offset-l3">
      <%= render @task %>
      <div class="center-align" style="margin-top: 1.5rem;">
        <%= link_to "Edit this task", edit_task_path(@task), class: "btn orange lighten-1 white-text" %>
        <%= link_to "Back to tasks", tasks_path, class: "btn-flat blue-text" %>
        <%= button_to "Destroy this task", @task, method: :delete, data: { confirm: "Are you sure?" }, class: "btn red lighten-1 white-text" %>
      </div>
    </div>
  </div>
</div>
